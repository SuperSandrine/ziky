---
import EventsPreview from "../components/EventsPreview.astro";
import HeroSection from "../components/HeroSection.astro";
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ShowsPreview from "../components/ShowsPreview.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { biography, pedagogyIntro, workshops } from "../data/site";
import Icon from "../components/Icon.astro";
---

<BaseLayout>
  <HeroSection />
  <ShowsPreview />
  <hr class="mx-auto max-w-6xl border-border" />
  <EventsPreview />
  <hr class="mx-auto max-w-6xl border-border" />

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <SectionHeading
          label="Pédagogie"
          title="Stages et Ateliers"
          description="Ateliers de clown inscrits dans le mouvement de l'éducation populaire, dans un cadre ludique et participatif."
        />
        <blockquote
          class="mt-8 border-l-2 border-accent pl-6 font-serif text-lg italic leading-relaxed text-muted-foreground"
        >
          {pedagogyIntro.quote}
        </blockquote>
        <a
          href="/stages"
          class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-foreground underline underline-offset-4 transition-colors hover:text-accent"
        >
          Découvrir les stages <Icon name="arrow-right" class="h-3.5 w-3.5" />
        </a>
      </div>
      <div class="flex flex-col gap-4">
        {
          workshops
            .slice(0, 3)
            .map((workshop) => <WorkshopCard workshop={workshop} compact />)
        }
        <a
          href="/stages"
          class="mt-2 flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          Voir tous les ateliers <Icon name="arrow-right" class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
  </section>

  <hr class="mx-auto max-w-6xl border-border" />

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-12 md:grid-cols-[1fr_2fr]">
      <ImagePlaceholder alt="Portrait de Ziky Versari" aspect="portrait" />
      <div class="flex flex-col justify-center">
        <SectionHeading label="Biographie" title="Parcours" />
        <p class="mt-6 leading-relaxed text-muted-foreground">
          {biography.full.split("\n\n")[0]}
        </p>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          {biography.full.split("\n\n")[1]}
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          {
            biography.disciplines.map((discipline) => (
              <span class="border border-border px-3 py-1 text-xs tracking-wide text-muted-foreground">
                {discipline}
              </span>
            ))
          }
        </div>
        <a
          href="/biographie"
          class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-foreground underline underline-offset-4 transition-colors hover:text-accent"
        >
          Lire la biographie complète <Icon
            name="arrow-right"
            class="h-3.5 w-3.5"
          />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
