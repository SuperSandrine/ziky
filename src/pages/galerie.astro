---
import GalleryGrid from "../components/GalleryGrid.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { galleryImages } from "../data/site";
import { editorialGalleryImages } from "../data/gallery-media";
import { showGalleryImages } from "../data/show-media";
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  { key: "all", label: "Tout" },
  { key: "spectacle", label: "Spectacle" },
  { key: "atelier", label: "Stages et atelier" },
  { key: "past-creations", label: "Créations passées" },
  { key: "portrait", label: "Portraits" },
] as const;

const images = [...showGalleryImages, ...editorialGalleryImages, ...galleryImages];
---

<BaseLayout
  title="Galerie | Ziky Versari"
  description="Photographies de spectacles, ateliers, créations passées et portraits de Ziky Versari."
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <SectionHeading
      label="Photographies"
      title="Galerie"
      description="Images de spectacles, ateliers, créations passées et portraits."
    />

    <GalleryGrid images={images} categories={categories} />
  </div>
</BaseLayout>
