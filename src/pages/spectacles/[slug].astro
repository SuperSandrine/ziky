---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { calendarEvents, contactEmail, shows } from "../../data/site";
import Icon from "../../components/Icon.astro";
import ImagePlaceholder from "../../components/ImagePlaceholder.astro";

export function getStaticPaths() {
  return shows.map((show) => ({
    params: { slug: show.slug },
    props: { show },
  }));
}

const { show } = Astro.props;

const statusLabel: Record<string, string> = {
  "en-tournee": "En tournee",
  "en-creation": "En creation",
  archive: "Archive",
};

const typeLabel: Record<string, string> = {
  solo: "Solo",
  duo: "Duo",
  collectif: "Collectif",
};

const related = shows.filter((item) => item.slug !== show.slug && item.type === show.type).slice(0, 3);
const upcomingDates = calendarEvents.filter(
  (event) =>
    event.title === show.title &&
    event.type === "spectacle" &&
    new Date(event.date) >= new Date(),
);
---

<BaseLayout title={`${show.title} | Ziky Versari`} description={show.shortDescription}>
  <div class="relative">
    <ImagePlaceholder alt={show.imagePlaceholder} aspect="wide" class="w-full" />
    <div class="absolute inset-0 bg-gradient-to-t from-foreground/70 via-transparent to-foreground/20"></div>
    <div class="absolute inset-x-0 bottom-0 px-6 pb-10">
      <div class="mx-auto max-w-6xl">
        <nav class="mb-4 flex items-center gap-2 text-xs text-background/60" aria-label="Fil d'Ariane">
          <a href="/" class="transition-colors hover:text-background/90">Accueil</a>
          <span>/</span>
          <a href="/spectacles" class="transition-colors hover:text-background/90">Spectacles</a>
          <span>/</span>
          <span class="text-background/90">{show.title}</span>
        </nav>
        <div class="mb-3 flex items-center gap-3">
          <span class="bg-accent px-2.5 py-1 text-[10px] font-medium uppercase tracking-wider text-accent-foreground">
            {statusLabel[show.status]}
          </span>
          <span class="text-sm text-background/70">{show.year}</span>
        </div>
        <h1 class="font-serif text-4xl text-background md:text-6xl">{show.title}</h1>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-12 lg:grid-cols-[2fr_1fr]">
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-4">
          <h2 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
            À propos du spectacle
          </h2>
          <p class="text-lg leading-relaxed text-foreground">{show.shortDescription}</p>
          {show.longDescription && (
            <div class="mt-4 flex flex-col gap-4">
              {show.longDescription.split("\n\n").map((paragraph) => (
                <p class="leading-relaxed text-muted-foreground">{paragraph}</p>
              ))}
            </div>
          )}
        </div>

        <div>
          <h2 class="mb-4 text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
            Galerie
          </h2>
          <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
            {[1, 2, 3].map((index) => (
              <ImagePlaceholder alt={`${show.title} - photo ${index}`} aspect="video" />
            ))}
          </div>
        </div>

        {upcomingDates.length > 0 && (
          <div>
            <h2 class="mb-4 text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
              Prochaines dates
            </h2>
            <div class="flex flex-col gap-3">
              {upcomingDates.map((event) => (
                <div class="flex items-center justify-between border-b border-border pb-3">
                  <div>
                    <time class="text-sm font-medium text-foreground" datetime={event.date}>
                      {new Date(event.date).toLocaleDateString("fr-FR", {
                        weekday: "long",
                        day: "numeric",
                        month: "long",
                        year: "numeric",
                      })}
                    </time>
                    <p class="text-xs text-muted-foreground">{event.location}</p>
                  </div>
                  <a href="/calendrier" class="text-xs text-foreground underline underline-offset-4">
                    Details
                  </a>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <aside class="flex flex-col gap-6">
        <div class="flex flex-col gap-4 border border-border bg-card p-6">
          <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
            Informations
          </h3>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3 text-sm">
              <span class="text-muted-foreground">Type</span>
              <span class="ml-auto text-foreground">{typeLabel[show.type]}</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-muted-foreground">Statut</span>
              <span class="ml-auto text-foreground">{statusLabel[show.status]}</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-muted-foreground">Annee</span>
              <span class="ml-auto text-foreground">{show.year}</span>
            </div>
          </div>

          <hr class="border-border" />

          <div>
            <h4 class="mb-2 text-xs text-muted-foreground">Roles</h4>
            <div class="flex flex-wrap gap-1.5">
              {show.roles.map((role) => (
                <span class="border border-border px-2.5 py-1 text-xs text-foreground">{role}</span>
              ))}
            </div>
          </div>
        </div>

        <a
          href={`mailto:${contactEmail}?subject=Programmation : ${show.title}`}
          class="flex items-center justify-center gap-2 bg-primary px-6 py-3.5 text-sm font-medium text-primary-foreground transition-all hover:scale-[1.02]"
        >
          <Icon name="mail" class="h-4 w-4" />
          Programmer ce spectacle
        </a>

        {show.externalLink && (
          <a
            href={show.externalLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 border border-foreground px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-foreground hover:text-background"
          >
            Site du spectacle <Icon name="arrow-up-right" class="h-4 w-4" />
          </a>
        )}

        {related.length > 0 && (
          <div class="mt-4">
            <h3 class="mb-4 text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
              Autres spectacles
            </h3>
            <div class="flex flex-col gap-3">
              {related.map((item) => (
                <a
                  href={`/spectacles/${item.slug}`}
                  class="group flex gap-3 border-b border-border pb-3 transition-colors last:border-0"
                >
                  <ImagePlaceholder alt={item.imagePlaceholder} aspect="video" class="w-20 shrink-0" />
                  <div class="flex flex-col gap-1">
                    <span class="font-serif text-sm text-foreground transition-colors group-hover:text-accent">
                      {item.title}
                    </span>
                    <span class="text-xs text-muted-foreground">{item.year}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>

    <div class="mt-16 border-t border-border pt-8">
      <a
        href="/spectacles"
        class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <Icon name="arrow-left" class="h-3.5 w-3.5" /> Tous les spectacles
      </a>
    </div>
  </div>
</BaseLayout>
