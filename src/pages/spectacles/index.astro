---
import SectionHeading from "../../components/SectionHeading.astro";
import SpectaclesArchive from "../../components/SpectaclesArchive.astro";
import { companies, shows } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const statusOrder: Record<string, number> = {
  "en-tournee": 0,
  "en-creation": 1,
  archive: 2,
};

const sortedShows = [...shows].sort((a, b) => statusOrder[a.status] - statusOrder[b.status]);
---

<BaseLayout
  title="Spectacles | Ziky Versari"
  description="Historique des creations de Ziky Versari : solos, duos et spectacles collectifs."
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <SectionHeading
      label="Creations"
      title="Spectacles"
      description="Solos, duos et creations collectives. Un parcours ou le corps debordant est matiere de contact et de relation au monde."
    />

    <SpectaclesArchive shows={sortedShows} />

    {companies.length > 0 && (
      <section class="mt-24 border-t border-border pt-16">
        <SectionHeading label="Collaborations" title="Compagnies" />
        <div class="mt-8 flex flex-col gap-6">
          {companies.map((company) => (
            <div class="flex flex-col gap-1 border-b border-border pb-6 last:border-0">
              <div class="flex items-baseline justify-between">
                <h3 class="font-serif text-xl text-foreground">
                  {company.url ? (
                    <a
                      href={company.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-colors hover:text-accent"
                    >
                      {company.name}
                    </a>
                  ) : (
                    company.name
                  )}
                </h3>
                <span class="text-sm text-muted-foreground">{company.period}</span>
              </div>
              <p class="text-sm text-muted-foreground">{company.role}</p>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
