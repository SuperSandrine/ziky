---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactEmail } from "../data/site";
import Icon from "../components/Icon.astro";
import SectionHeading from "../components/SectionHeading.astro";
import contactPhoto from "../assets/images/portrait/photo contact.webp";
---

<BaseLayout
  title="Contact | Ziky Versari"
  description="Contacter Ziky Versari pour un spectacle, un stage ou une collaboration."
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="overflow-hidden border border-border bg-card">
      <div class="flex flex-col lg:min-h-[720px] lg:flex-row">
        <div class="relative lg:w-[46%]">
          <Image
            src={contactPhoto}
            alt="Portrai de Ziky Versari en pied"
            class="h-full min-h-[320px] w-full object-cover"
            loading="eager"
            priority
            sizes="(max-width: 1024px) 100vw, 46vw"
            format="webp"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-foreground/30 via-transparent to-transparent"
          >
          </div>
        </div>

        <div
          class="flex flex-1 flex-col justify-center px-8 py-10 sm:px-10 lg:px-12 lg:py-14"
        >
          <SectionHeading
            title="Contact"
            description="Pour une programmation, un stage, une collaboration ou simplement échanger."
          />

          <div
            class="mt-12 flex flex-col gap-8"
            data-contact-copy-root
            data-email={contactEmail}
          >
            <button
              type="button"
              class="group flex w-fit items-center gap-4 text-left"
              data-copy-email
              aria-label="Copier l'adresse mail"
            >
              <span
                class="flex h-16 w-16 items-center justify-center rounded-full bg-primary text-primary-foreground transition-transform group-hover:scale-110"
              >
                <Icon name="mail" class="h-6 w-6" />
              </span>
              <span
                class="text-lg text-foreground underline underline-offset-4 transition-colors group-hover:text-accent"
              >
                {contactEmail}
              </span>
            </button>
            <p
              class="pointer-events-none -mt-4 translate-y-[-10px] opacity-0 transition-all duration-500 ease-out text-sm text-accent"
              data-copy-feedback
            >
              Adresse mail copiée
            </p>

            <div class="flex items-center gap-3 text-muted-foreground">
              <Icon name="map-pin" class="h-5 w-5" />
              <span>Basée dans la Creuse, France</span>
            </div>
          </div>

          <!-- <div class="mt-12 border-t border-border pt-10">
            <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
              Je souhaite...
            </h3>
            <div class="mt-6 flex flex-col gap-3">
              <a
                href={`mailto:${contactEmail}?subject=Programmation de spectacle`}
                class="flex items-center gap-2 text-sm text-foreground transition-colors hover:text-accent"
              >
                Programmer un spectacle <Icon name="arrow-right" class="h-3.5 w-3.5" />
              </a>
              <a
                href={`mailto:${contactEmail}?subject=Organisation d'un stage ou atelier`}
                class="flex items-center gap-2 text-sm text-foreground transition-colors hover:text-accent"
              >
                Organiser un stage ou atelier <Icon name="arrow-right" class="h-3.5 w-3.5" />
              </a>
              <a
                href={`mailto:${contactEmail}?subject=Collaboration artistique`}
                class="flex items-center gap-2 text-sm text-foreground transition-colors hover:text-accent"
              >
                Proposer une collaboration <Icon name="arrow-right" class="h-3.5 w-3.5" />
              </a>
            </div>
          </div> -->

          <hr class="mt-12 w-16 border-accent" />

          <!-- <p class="mt-8 max-w-xl text-sm leading-relaxed text-muted-foreground">
            Artiste indépendante, Ziky Versari est à l'écoute. N'hésitez pas à la contacter pour toute question, proposition ou simplement pour échanger sur la musique et les arts vivants.
          </p> -->

          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="/spectacles"
              class="border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
            >
              Voir les spectacles
            </a>
            <a
              href="/stages"
              class="border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
            >
              Voir les stages
            </a>
            <a
              href="/calendrier"
              class="border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
            >
              Voir l'agenda
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const root = document.querySelector("[data-contact-copy-root]");
  if (root instanceof HTMLElement) {
    const trigger = root.querySelector("[data-copy-email]");
    const feedback = root.querySelector("[data-copy-feedback]");
    const email = root.dataset.email || "";
    let feedbackTimeout;

    const showFeedback = () => {
      if (!(feedback instanceof HTMLElement)) return;
      feedback.classList.remove("-mt-4", "translate-y-[-10px]", "opacity-0");
      feedback.classList.add("mt-0", "translate-y-0", "opacity-100");
      clearTimeout(feedbackTimeout);
      feedbackTimeout = window.setTimeout(() => {
        feedback.classList.remove("mt-0", "translate-y-0", "opacity-100");
        feedback.classList.add("-mt-4", "translate-y-[-10px]", "opacity-0");
      }, 5000);
    };

    const copyEmail = async () => {
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        showFeedback();
      } catch {
        const fallback = document.createElement("textarea");
        fallback.value = email;
        fallback.setAttribute("readonly", "");
        fallback.style.position = "absolute";
        fallback.style.left = "-9999px";
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand("copy");
        document.body.removeChild(fallback);
        showFeedback();
      }
    };

    trigger?.addEventListener("click", copyEmail);
  }
</script>
