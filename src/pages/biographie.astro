---
import BaseLayout from "../layouts/BaseLayout.astro";
import { biography, biographyTimeline, companies, formations } from "../data/site";
import Icon from "../components/Icon.astro";
import SectionHeading from "../components/SectionHeading.astro";
import biographyPortrait from "../assets/images/portrait/contact 1.webp";
import biographyImageOne from "../assets/images/portrait/biographie.webp";
import biographyImageTwo from "../assets/images/portrait/biographie (2).webp";
import biographyImageThree from "../assets/images/portrait/biographie 3.webp";
import homePortrait from "../assets/images/portrait/photo d'acueil.webp";

const paragraphs = biography.full.split("\n\n");
const biographyGallery = [
  { src: biographyImageOne.src, alt: "Ziky Versari en biographie 1" },
  { src: biographyImageTwo.src, alt: "Ziky Versari en biographie 2" },
  { src: biographyImageThree.src, alt: "Ziky Versari en biographie 3" },
  { src: biographyPortrait.src, alt: "Portrait de Ziky Versari" },
  {
    src: homePortrait.src,
    alt: "Photo d'accueil de Ziky Versari",
    imageClassName: "object-[10%_22%]",
  },
];

const disciplineIcons: Record<string, string> = {
  Clown: "C",
  "Jonglage antipodiste": "J",
  "Écriture": "E",
  "Mise en scène": "M",
  Pédagogie: "P",
};
---

<BaseLayout
  title="Biographie | Ziky Versari"
  description="Biographie de Ziky Versari, clown, jongleureuse antipodiste et pédagogue."
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <SectionHeading label="Biographie" title="Biographie" />
    <div class="mt-1 h-px w-16 bg-accent" aria-hidden="true"></div>

    <div class="mt-16 grid gap-12 md:grid-cols-[2fr_3fr]">
      <div class="flex flex-col gap-4">
        <img
          src={biographyPortrait.src}
          alt="Portrait de Ziky Versari"
          class="aspect-3/4 w-full rounded-sm object-cover shadow-lg"
          loading="lazy"
        />
        <p class="text-center text-xs text-muted-foreground">
          Ziky Versari - Photo : crédit à venir
        </p>
      </div>

      <div class="flex flex-col justify-center">
        <p class="text-sm uppercase tracking-wider text-muted-foreground">
          Spectacle vivant : clown, cirque et pédagogie
        </p>
        <h2 class="mt-4 font-serif text-3xl text-foreground md:text-4xl">Ziky Versari</h2>
        <div class="mt-6 flex flex-col gap-5">
          {paragraphs.slice(0, 3).map((paragraph) => (
            <p class="leading-relaxed text-muted-foreground">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>

    <div class="mx-auto mt-12 flex max-w-3xl flex-col gap-5">
      {paragraphs.slice(3).map((paragraph) => (
        <p class="leading-relaxed text-muted-foreground">{paragraph}</p>
      ))}
    </div>

    <div class="mx-auto mt-16 max-w-5xl border-t border-border pt-12">
      <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Galerie
      </h3>
      <p class="mt-3 max-w-2xl leading-relaxed text-muted-foreground">
        Quelques images pour traverser le parcours, les matières de jeu et les présences qui accompagnent le travail de Ziky Versari.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {biographyGallery.map((image) => (
          <figure class="overflow-hidden rounded-sm bg-muted">
            <img
              src={image.src}
              alt={image.alt}
              class:list={[
                "h-72 w-full object-cover transition-transform duration-500 hover:scale-[1.03]",
                image.imageClassName,
              ]}
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-3xl border-t border-border pt-12">
      <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Historique
      </h3>
      <div class="mt-8 flex flex-col gap-6">
        {biographyTimeline.map((item) => (
          <div class="grid gap-3 border-l border-border pl-5 md:grid-cols-[140px_1fr] md:gap-6">
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-accent">
              {item.date}
            </span>
            <div class="pb-6">
              <h4 class="font-serif text-xl text-foreground">{item.title}</h4>
              <p class="mt-2 leading-relaxed text-muted-foreground">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-3xl border-t border-border pt-12">
      <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Disciplines pratiquées
      </h3>
      <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {biography.disciplines.map((discipline) => (
          <div class="flex flex-col items-center gap-3 border border-border p-5 text-center transition-colors hover:border-accent">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-muted font-serif text-lg text-foreground">
              {disciplineIcons[discipline] || discipline[0]}
            </span>
            <span class="text-xs tracking-wide text-foreground">{discipline}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-12 max-w-3xl border-t border-border pt-12">
      <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Formations
      </h3>
      <div class="mt-6 flex flex-col gap-4">
        {formations.map((school) => (
          <div class="flex items-center gap-4 border-b border-border pb-4 last:border-0">
            <span class="h-2 w-2 shrink-0 rounded-full bg-accent"></span>
            <div>
              <span class="text-sm text-foreground">{school.name}</span>
              <span class="ml-2 text-xs text-muted-foreground">{school.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    {companies.length > 0 && (
      <div class="mx-auto mt-12 max-w-3xl border-t border-border pt-12">
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
          Collaborations
        </h3>
        <div class="mt-6 flex flex-col gap-6">
          {companies.map((company) => (
            <div class="flex items-baseline justify-between border-b border-border pb-4">
              <div>
                <span class="font-serif text-lg text-foreground">{company.name}</span>
                <span class="ml-3 text-sm text-muted-foreground">{company.role}</span>
              </div>
              <span class="text-sm text-muted-foreground">{company.period}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="mx-auto mt-16 flex max-w-3xl flex-wrap gap-4">
      <a
        href="/spectacles"
        class="inline-flex items-center gap-2 bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-all hover:scale-[1.02]"
      >
        Découvrir mes spectacles <Icon name="arrow-right" class="h-4 w-4" />
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 border border-foreground px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-foreground hover:text-background"
      >
        Me contacter
      </a>
    </div>
  </div>
</BaseLayout>
