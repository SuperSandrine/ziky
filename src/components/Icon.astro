---
interface Props {
  name:
    | "arrow-right"
    | "arrow-left"
    | "arrow-up-right"
    | "chevron-down"
    | "clock"
    | "users"
    | "mail"
    | "map-pin"
    | "calendar-days"
    | "menu"
    | "x"
    | "image";
  class?: string;
}

const { name, class: className = "h-4 w-4" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === "arrow-right" && (
    <>
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </>
  )}
  {name === "arrow-left" && (
    <>
      <path d="M19 12H5" />
      <path d="m12 19-7-7 7-7" />
    </>
  )}
  {name === "arrow-up-right" && (
    <>
      <path d="M7 17 17 7" />
      <path d="M7 7h10v10" />
    </>
  )}
  {name === "chevron-down" && <path d="m6 9 6 6 6-6" />}
  {name === "clock" && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 3" />
    </>
  )}
  {name === "users" && (
    <>
      <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
      <path d="M9.5 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
      <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
    </>
  )}
  {name === "mail" && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m4 7 8 6 8-6" />
    </>
  )}
  {name === "map-pin" && (
    <>
      <path d="M12 21s-6-5.33-6-11a6 6 0 1 1 12 0c0 5.67-6 11-6 11Z" />
      <circle cx="12" cy="10" r="2.5" />
    </>
  )}
  {name === "calendar-days" && (
    <>
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <path d="M16 2v4" />
      <path d="M8 2v4" />
      <path d="M3 10h18" />
      <path d="M8 14h.01" />
      <path d="M12 14h.01" />
      <path d="M16 14h.01" />
      <path d="M8 18h.01" />
      <path d="M12 18h.01" />
      <path d="M16 18h.01" />
    </>
  )}
  {name === "menu" && (
    <>
      <path d="M4 12h16" />
      <path d="M4 6h16" />
      <path d="M4 18h16" />
    </>
  )}
  {name === "x" && (
    <>
      <path d="M18 6 6 18" />
      <path d="m6 6 12 12" />
    </>
  )}
  {name === "image" && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <circle cx="8.5" cy="10" r="1.5" />
      <path d="m21 15-5-5L5 21" />
    </>
  )}
</svg>
