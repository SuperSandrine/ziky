  <div class="mt-12 flex flex-col gap-20" data-results>
    {showsByYear.map((group) => (
      <section class="flex flex-col gap-10" data-year-group={group.year}>
        <div class="border-b border-border pb-3">
          <h2 class="font-serif text-3xl text-foreground">{group.year}</h2>
        </div>

        <div class="flex flex-col gap-16">
          {group.shows.map((show) => (
            <article
              id={show.slug}
              class="group grid gap-8 scroll-mt-24 md:grid-cols-2"
              data-show
              data-title={show.title.toLowerCase()}
              data-description={show.shortDescription.toLowerCase()}
              data-roles={show.roles.join("|")}
            >
              <a href={`/spectacles/${show.slug}`} class="overflow-hidden rounded-sm">
                {showMedia[show.slug]?.cover ? (
                  <img
                    src={showMedia[show.slug].cover.src}
                    alt={showMedia[show.slug].cover.alt}
                    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                ) : (
                  <ImagePlaceholder
                    alt={show.imagePlaceholder}
                    aspect="video"
                    class="transition-transform duration-500 group-hover:scale-[1.03]"
                  />
                )}
              </a>
              <div class="flex flex-col justify-center gap-4">
                <div class="flex items-center gap-3">
                  <span class="text-xs font-medium uppercase tracking-wider text-accent">
                    {statusLabel[show.status]}
                  </span>
                  <span class="text-xs text-muted-foreground">{show.year}</span>
                  <span class="border border-border px-2 py-0.5 text-[11px] text-muted-foreground">
                    {typeLabel[show.type]}
                  </span>
                </div>
                <a href={`/spectacles/${show.slug}`}>
                  <h3 class="font-serif text-3xl text-foreground transition-colors hover:text-accent">
                    {show.title}
                  </h3>
                </a>
                <p class="leading-relaxed text-muted-foreground">{show.shortDescription}</p>
                <div class="flex flex-wrap gap-2">
                  {show.roles.map((role) => (
                    <span class="border border-border px-3 py-1 text-xs tracking-wide text-muted-foreground">
                      {role}
                    </span>
                  ))}
                </div>
                <div class="flex items-center gap-4 pt-2">
                  <a
                    href={`/spectacles/${show.slug}`}
                    class="text-sm text-foreground underline underline-offset-4 transition-colors hover:text-accent"
                  >
                    En savoir plus
                  </a>
                  {show.externalLink && (
                    <a
                      href={show.externalLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
                    >
                      Site <Icon name="arrow-up-right" class="h-3 w-3" />
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>

  <div class="hidden flex-col items-center gap-4 py-20 text-center" data-empty-state>
    <p class="text-muted-foreground">Aucun spectacle ne correspond à votre recherche.</p>
    <button type="button" class="text-sm text-foreground underline underline-offset-4" data-empty-reset>
      Voir tous les spectacles
    </button>
  </div>
</div>

