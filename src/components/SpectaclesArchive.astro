---
import type { Show } from "../data/site";
import { showMedia } from "../data/show-media";
import Icon from "./Icon.astro";
import ImagePlaceholder from "./ImagePlaceholder.astro";

interface Props {
  shows: Show[];
}

const { shows } = Astro.props;

const yearValue = (year: string) => {
  const match = year.match(/\d{4}/);
  return match ? Number(match[0]) : Number.NEGATIVE_INFINITY;
};

const sortedShows = [...shows].sort((a, b) => {
  const yearDiff = yearValue(b.year) - yearValue(a.year);
  if (yearDiff !== 0) return yearDiff;
  return a.title.localeCompare(b.title, "fr");
});

const showsByYear = sortedShows.reduce(
  (groups, show) => {
    const existing = groups.find((group) => group.year === show.year);
    if (existing) {
      existing.shows.push(show);
    } else {
      groups.push({ year: show.year, shows: [show] });
    }
    return groups;
  },
  [] as { year: string; shows: Show[] }[],
);

const statusLabel: Record<string, string> = {
  "en-tournee": "En tournée",
  "en-creation": "En création",
  archive: "Archive",
};

const typeLabel: Record<string, string> = {
  solo: "Solo",
  duo: "Duo",
  collectif: "Collectif",
};

// const disciplines = ["Clown", "Écriture", "Interprétation", "Mise en scène", "Cofondatrice"];
---

<div data-spectacles-archive>
