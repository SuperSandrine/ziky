---
import { calendarEvents } from "../data/site";
import Icon from "./Icon.astro";
import SectionHeading from "./SectionHeading.astro";

const typeLabel: Record<string, string> = {
  spectacle: "Spectacle",
  stage: "Stage",
  atelier: "Atelier",
};

const typeStyles: Record<string, string> = {
  spectacle: "bg-primary text-primary-foreground",
  stage: "bg-accent text-accent-foreground",
  atelier: "border border-border text-foreground",
};

const futureEvents = calendarEvents
  .filter((event) => new Date(event.date) >= new Date())
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 3);

function formatShortDate(dateStr: string) {
  const date = new Date(dateStr);
  return {
    day: date.toLocaleDateString("fr-FR", { weekday: "short" }),
    num: date.getDate().toString().padStart(2, "0"),
    month: date.toLocaleDateString("fr-FR", { month: "short" }),
  };
}
---

{
  futureEvents.length === 0 ? (
    <section class="mx-auto max-w-6xl px-6 py-24">
      <SectionHeading label="Agenda" title="Prochains événements" />
      <div class="mt-12 flex flex-col items-center gap-4 py-12 text-center">
        <Icon name="calendar-days" class="h-10 w-10 text-muted-foreground/30" />
        <p class="text-muted-foreground">Aucun événement à venir pour le moment.</p>
      </div>
    </section>
  ) : (
    <section class="mx-auto max-w-6xl px-6 py-24">
      <div class="flex items-end justify-between">
        <SectionHeading label="Agenda" title="Prochains événements" />
        <a
          href="/calendrier"
          class="hidden items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground md:flex"
        >
          Voir tout l'agenda <Icon name="arrow-right" class="h-3.5 w-3.5" />
        </a>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {futureEvents.map((event) => {
          const d = formatShortDate(event.date);
          return (
            <article class="group flex flex-col border border-border bg-card transition-all hover:-translate-y-0.5 hover:shadow-md">
              <div class="flex items-start gap-4 p-5">
                <div class="shrink-0 bg-primary px-3 py-2 text-primary-foreground">
                  <div class="flex flex-col items-center">
                    <span class="text-[10px] uppercase tracking-wider opacity-70">{d.day}</span>
                    <span class="font-serif text-2xl leading-none">{d.num}</span>
                    <span class="text-[10px] uppercase tracking-wider opacity-70">{d.month}</span>
                  </div>
                </div>
                <div class="min-w-0 flex flex-col gap-2">
                  <span class={`inline-block w-fit px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider ${typeStyles[event.type]}`}>
                    {typeLabel[event.type]}
                  </span>
                  <h3 class="truncate font-serif text-lg text-card-foreground">{event.title}</h3>
                </div>
              </div>

              <div class="flex flex-col gap-2 border-t border-border px-5 py-4">
                <div class="flex items-center gap-2 text-xs text-muted-foreground">
                  <Icon name="map-pin" class="h-3 w-3 shrink-0" />
                  {event.location}
                </div>
                {event.description && (
                  <p class="line-clamp-2 text-xs text-muted-foreground">{event.description}</p>
                )}
              </div>

              <a
                href="/calendrier"
                class="flex items-center gap-1 border-t border-border px-5 py-3 text-xs text-muted-foreground transition-colors group-hover:text-foreground"
              >
                En savoir plus <Icon name="arrow-right" class="h-3 w-3" />
              </a>
            </article>
          );
        })}
      </div>

      <a
        href="/calendrier"
        class="mt-8 flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground md:hidden"
      >
        Voir tout l'agenda <Icon name="arrow-right" class="h-3.5 w-3.5" />
      </a>
    </section>
  )
}
