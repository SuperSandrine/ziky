---
interface Props {
  label?: string;
  title: string;
  description?: string;
  class?: string;
}

const { label, title, description, class: className = "" } = Astro.props;
---

<div class={`flex flex-col gap-3 ${className}`}>
  {label && (
    <span class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
      {label}
    </span>
  )}
  <h2 class="font-serif text-3xl leading-tight text-foreground md:text-4xl text-balance">
    {title}
  </h2>
  {description && (
    <p class="max-w-2xl leading-relaxed text-muted-foreground">{description}</p>
  )}
</div>
