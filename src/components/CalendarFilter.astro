---
import type { CalendarEvent } from "../data/site";
import { shows } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  events: CalendarEvent[];
}

const { events } = Astro.props;

const typeFilters = [
  { key: "all", label: "Tous les types" },
  { key: "spectacle", label: "Spectacles" },
  { key: "practice", label: "Stage et atelier" },
] as const;

const typeLabel: Record<string, string> = {
  spectacle: "Spectacle",
  stage: "Stage",
  atelier: "Atelier",
};

const typeColor: Record<string, string> = {
  spectacle: "bg-primary text-primary-foreground",
  stage: "bg-accent text-accent-foreground",
  atelier: "border border-border bg-card text-foreground",
};

const statusBadge: Record<string, { label: string; className: string }> = {
  complet: { label: "Complet", className: "bg-destructive text-destructive-foreground" },
  annule: { label: "Annulé", className: "bg-muted text-muted-foreground" },
  "dernieres-places": { label: "Dernières places", className: "bg-accent text-accent-foreground" },
};

const futureEvents = events
  .filter((event) => new Date(event.date) >= new Date())
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = events
  .filter((event) => new Date(event.date) < new Date())
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("fr-FR", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

function formatDayParts(dateStr: string) {
  const date = new Date(dateStr);
  return {
    dayName: date.toLocaleDateString("fr-FR", { weekday: "long" }),
    dayNum: date.getDate().toString().padStart(2, "0"),
    month: date.toLocaleDateString("fr-FR", { month: "long" }),
    year: date.getFullYear().toString(),
  };
}

function normalizeForMatch(value: string) {
  return value
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
}

function getEventLink(event: CalendarEvent) {
  if (event.link) return event.link;
  if (event.type !== "spectacle") return null;

  const normalizedTitle = normalizeForMatch(event.title);
  const matchingShow = shows.find((show) => {
    const normalizedShowTitle = normalizeForMatch(show.title);
    return (
      normalizedTitle.includes(normalizedShowTitle) ||
      normalizedShowTitle.includes(normalizedTitle)
    );
  });

  return matchingShow ? `/spectacles/${matchingShow.slug}` : null;
}
---

<div data-calendar-filter>
  <div class="mt-12 flex flex-wrap items-center gap-3">
    {typeFilters.map((filter, index) => (
      <button
        type="button"
        class:list={[
          "px-4 py-2 text-sm transition-colors",
          index === 0
            ? "bg-foreground text-background"
            : "border border-border text-muted-foreground hover:text-foreground",
        ]}
        data-filter-button={filter.key}
      >
        {filter.label}
      </button>
    ))}

    <button
      type="button"
      class="hidden items-center gap-1 px-3 py-2 text-xs text-muted-foreground transition-colors hover:text-foreground"
      data-filter-reset
    >
      <Icon name="x" class="h-3 w-3" /> Tout effacer
    </button>
  </div>

  <p class="mt-4 text-xs text-muted-foreground" data-future-count>
    {futureEvents.length} événement{futureEvents.length !== 1 ? "s" : ""} à venir
  </p>

  <div class="mt-8">
    <div class={futureEvents.length === 0 ? "flex flex-col items-center gap-4 py-20 text-center" : "hidden"} data-empty-message>
      <Icon name="calendar-days" class="h-12 w-12 text-muted-foreground/30" />
      <p class="text-muted-foreground">Les prochaines dates seront annoncées bientôt.</p>
    </div>

    <div class="flex flex-col gap-0" data-future-list>
      {futureEvents.map((event) => {
        const d = formatDayParts(event.date);
        const badge = event.status ? statusBadge[event.status] : null;
        const eventLink = getEventLink(event);
        return (
          <article
            class="group border-b border-border py-8 first:pt-0"
            data-event
            data-type={event.type}
          >
            <div class="grid gap-6 md:grid-cols-[180px_1fr_auto]">
              <div class="flex flex-col">
                <span class="text-xs uppercase tracking-wider text-muted-foreground">{d.dayName}</span>
                <time class="mt-1 font-serif text-3xl leading-none text-foreground" datetime={event.date}>
                  {d.dayNum}
                </time>
                <span class="mt-0.5 text-sm text-muted-foreground">{d.month} {d.year}</span>
                {event.time && (
                  <span class="mt-2 flex items-center gap-1 text-xs text-muted-foreground">
                    <Icon name="clock" class="h-3 w-3" /> {event.time}
                  </span>
                )}
                {event.endDate && (
                  <span class="mt-1 text-xs text-muted-foreground">-&gt; {formatDate(event.endDate)}</span>
                )}
              </div>

              <div class="flex flex-col gap-2">
                <div class="flex flex-wrap items-center gap-2">
                  <span class={`inline-block px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider ${typeColor[event.type]}`}>
                    {typeLabel[event.type]}
                  </span>
                  {badge && (
                    <span class={`inline-block px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider ${badge.className}`}>
                      {badge.label}
                    </span>
                  )}
                </div>
                <h3 class="font-serif text-xl text-foreground">{event.title}</h3>
                {event.description && (
                  <p class="line-clamp-2 text-sm text-muted-foreground">{event.description}</p>
                )}
                <div class="mt-1 flex flex-wrap items-center gap-4">
                  {event.audience && (
                    <span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <Icon name="users" class="h-3 w-3" /> {event.audience}
                    </span>
                  )}
                  {event.price && <span class="text-xs text-muted-foreground">{event.price}</span>}
                </div>
              </div>

              <div class="flex flex-col items-start gap-3 md:items-end">
                <div class="flex items-start gap-1.5 text-sm text-muted-foreground">
                  <Icon name="map-pin" class="mt-0.5 h-3.5 w-3.5 shrink-0" />
                  <div class="flex flex-col">
                    <span>{event.location}</span>
                    {event.venue && <span class="text-xs opacity-70">{event.venue}</span>}
                  </div>
                </div>
                {eventLink && (
                  <a
                    href={eventLink}
                    class="flex items-center gap-1 text-xs text-foreground underline underline-offset-4 transition-colors hover:text-accent"
                  >
                    En savoir plus <Icon name="arrow-right" class="h-3 w-3" />
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  {pastEvents.length > 0 && (
    <section class="mt-16 border-t border-border pt-12">
      <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Dates passées
      </h3>
      <div class="mt-6 flex flex-col gap-0">
        {pastEvents.map((event) => (
          <div class="flex items-baseline justify-between border-b border-border py-4 text-muted-foreground">
            <div class="flex items-center gap-3">
              <span class="text-xs uppercase tracking-wider opacity-60">{typeLabel[event.type]}</span>
              <span class="text-sm">{event.title}</span>
              {event.location && <span class="hidden text-xs opacity-50 sm:inline">- {event.location}</span>}
            </div>
            <time class="ml-4 shrink-0 text-xs" datetime={event.date}>{formatDate(event.date)}</time>
          </div>
        ))}
      </div>
      <p class="mt-6 text-sm text-muted-foreground">
        Spectacle passé ? Contactez Ziky.
      </p>
    </section>
  )}
</div>

<script>
  const root = document.querySelector("[data-calendar-filter]");
  if (root) {
    const buttons = Array.from(root.querySelectorAll("[data-filter-button]"));
    const reset = root.querySelector("[data-filter-reset]");
    const events = Array.from(root.querySelectorAll("[data-event]"));
    const empty = root.querySelector("[data-empty-message]");
    const list = root.querySelector("[data-future-list]");
    const count = root.querySelector("[data-future-count]");

    const setFilter = (value) => {
      let visible = 0;
      buttons.forEach((button) => {
        const active = button.dataset.filterButton === value;
        button.classList.toggle("bg-foreground", active);
        button.classList.toggle("text-background", active);
        button.classList.toggle("border", !active);
        button.classList.toggle("border-border", !active);
        button.classList.toggle("text-muted-foreground", !active);
      });

      events.forEach((event) => {
        const eventType = event.dataset.type;
        const show =
          value === "all" ||
          eventType === value ||
          (value === "practice" && (eventType === "stage" || eventType === "atelier"));
        event.classList.toggle("hidden", !show);
        if (show) visible += 1;
      });

      if (count) {
        count.textContent = `${visible} événement${visible !== 1 ? "s" : ""} à venir`;
      }

      empty?.classList.toggle("hidden", visible !== 0);
      empty?.classList.toggle("flex", visible === 0);
      list?.classList.toggle("hidden", visible === 0);
      reset?.classList.toggle("hidden", value === "all");
      reset?.classList.toggle("inline-flex", value !== "all");
      if (empty?.querySelector("p")) {
        empty.querySelector("p").textContent =
          value === "all"
            ? "Les prochaines dates seront annoncées bientôt."
            : "Aucun événement de ce type à venir.";
      }
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => setFilter(button.dataset.filterButton || "all"));
    });
    reset?.addEventListener("click", () => setFilter("all"));
  }
</script>
