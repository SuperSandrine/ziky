---
import { faqItems } from "../data/site";
import Icon from "./Icon.astro";
---

<div class="flex flex-col">
  {faqItems.map((item) => (
    <details class="group border-b border-border py-1">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-left transition-colors hover:text-accent">
        <span class="text-sm font-medium text-foreground">{item.question}</span>
        <Icon
          name="chevron-down"
          class="h-4 w-4 shrink-0 text-muted-foreground transition-transform duration-300 group-open:rotate-180"
        />
      </summary>
      <p class="pb-4 text-sm leading-relaxed text-muted-foreground">{item.answer}</p>
    </details>
  ))}
</div>
